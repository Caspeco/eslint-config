{
	"name": "@caspeco/eslint-config-ts",
	"version": "5.2.0",
	"description": "Caspeco ESLint configuration for TypeScript projects",
	"keywords": [
		"eslint",
		"eslint-config",
		"typescript",
		"caspeco"
	],
	"homepage": "https://github.com/Caspeco/eslint-config#readme",
	"bugs": {
		"url": "https://github.com/Caspeco/eslint-config/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Caspeco/eslint-config",
		"directory": "packages/eslint-config-ts"
	},
	"license": "MIT",
	"type": "module",
	"main": "src/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"caspeco-ts-migrate-v5": "./bin/caspeco-ts-migrate-v5.js"
	},
	"files": [
		"src",
		"bin",
		"dist"
	],
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"check:types": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
		"prepublishOnly": "npm run build",
		"test": "vitest"
	},
	"devDependencies": {
		"@caspeco/test-utils": "*",
		"@eslint/js": "^9.39.4",
		"@typescript-eslint/utils": "^8.59.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-check-file": "^3.3.1",
		"eslint-plugin-no-barrel-files": "^1.3.1",
		"typescript-eslint": "^8.59.0"
	},
	"peerDependencies": {
		"@eslint/js": "^9.39.4",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-check-file": "^3.3.1",
		"eslint-plugin-no-barrel-files": "^1.2.2",
		"typescript-eslint": "^8.57.2"
	},
	"engines": {
		"node": ">=24",
		"npm": ">=11.5.1"
	},
	"publishConfig": {
		"access": "public"
	}
}
